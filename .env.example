# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_publica_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_secret_key_aqui
DATABASE_URL=postgresql://postgres:sua_senha@db.seu-projeto.supabase.co:5432/postgres

# --- PROVEDORES DE IA ---
GROQ_API_KEY=sua_groq_api_key_aqui
GEMINI_API_KEY=sua_gemini_api_key_aqui
OPENAI_API_KEY=sua_openai_api_key_aqui
ANTHROPIC_API_KEY=sua_anthropic_api_key_aqui

# --- GERAÇÃO DE IMAGENS E DADOS ---
OPENAI_IMAGE_API_KEY=sua_openai_image_api_key_aqui
UNSPLASH_ACCESS_KEY=sua_unsplash_access_key_aqui
UNSPLASH_SECRET_KEY=sua_unsplash_secret_key_aqui
TMDB_API_KEY=sua_tmdb_api_key_aqui
TMDB_READ_TOKEN=seu_tmdb_read_token_aqui
OMDB_API_KEY=sua_omdb_api_key_aqui
API_FOOTBALL_KEY=sua_api_football_key_aqui
FOOTBALL_DATA_TOKEN=seu_football_data_token_aqui

# --- ADMIN DE SEGURANÇA ---
ADMIN_SECRET=sua_chave_admin_secret_aqui

# --- SITE PUBLICO ---
NEXT_PUBLIC_SITE_URL=https://cine-play-seven.vercel.app
NEXT_PUBLIC_SITE_NAME=CinePlay
NEXT_PUBLIC_SITE_DESCRIPTION=Tudo sobre streaming, futebol ao vivo, séries e filmes
